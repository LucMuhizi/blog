{
  "name": "blog",
  "type": "module",
  "version": "7.0.0",
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22 <27"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucMuhizi/blog.git"
  },
  "bugs": {
    "url": "https://github.com/LucMuhizi/blog/issues"
  },
  "homepage": "https://github.com/LucMuhizi/blog#readme",
  "scripts": {
    "dev": "astro dev",
    "dev:background": "astro dev --background",
    "dev:status": "astro dev status",
    "dev:logs": "astro dev logs",
    "dev:stop": "astro dev stop",
    "dev:json": "astro dev --json",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:upgrade": "node --test scripts/verify-astro-7-upgrade.test.mjs",
    "migrate:dry-run": "node --env-file-if-exists=.env.local scripts/migrate-from-wix.mjs --plan --verbose",
    "migrate:live": "node --env-file-if-exists=.env.local scripts/migrate-from-wix.mjs --live --confirm",
    "migrate:fresh": "node --env-file-if-exists=.env.local scripts/migrate-from-wix.mjs --plan --fresh --verbose",
    "migrate:scrape:dry-run": "node --env-file-if-exists=.env.local scripts/migrate-from-wix-playwright.mjs --plan --verbose",
    "migrate:scrape:live": "node --env-file-if-exists=.env.local scripts/migrate-from-wix-playwright.mjs --live --confirm",
    "migrate:scrape:fresh": "node --env-file-if-exists=.env.local scripts/migrate-from-wix-playwright.mjs --plan --fresh --verbose",
    "migrate:medium:dry-run": "node --env-file-if-exists=.env.local scripts/migrate-from-medium.mjs --plan --verbose",
    "migrate:medium:live": "node --env-file-if-exists=.env.local scripts/migrate-from-medium.mjs --live --confirm",
    "migrate:medium:fresh": "node --env-file-if-exists=.env.local scripts/migrate-from-medium.mjs --plan --fresh --verbose",
    "migrate:medium:archive:dry-run": "node --env-file-if-exists=.env.local scripts/scrape-medium-archive.mjs --plan --verbose",
    "migrate:medium:archive:live": "node --env-file-if-exists=.env.local scripts/scrape-medium-archive.mjs --live --confirm",
    "migrate:medium:archive:fresh": "node --env-file-if-exists=.env.local scripts/scrape-medium-archive.mjs --plan --fresh --verbose",
    "migrate:medium:archive:preview": "node --env-file-if-exists=.env.local scripts/scrape-medium-archive.mjs --plan --fresh --max-new 5 --verbose",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.106",
    "@solana/kit": "^5.5.1",
    "@solana/sysvars": "5.5.1",
    "@tailwindcss/vite": "^4.2.1",
    "@x402/core": "^2.14.0",
    "@x402/hono": "^2.14.0",
    "@x402/svm": "^2.14.0",
    "astro": "^7.0.3",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "hono": "^4.12.23",
    "pagefind": "^1.5.2",
    "sirv": "^3.0.2",
    "tailwindcss": "^4.2.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.19",
    "playwright": "^1.48.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.3",
    "wrangler": "^4.90.0"
  }
}

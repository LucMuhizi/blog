---
import "@/styles/global.css"
import { SEO } from "astro-seo"
import { ClientRouter } from "astro:transitions"
import { SITE_LANGUAGE_VALUE, SITE_OG_LOCALE_VALUE } from "@/utils/structured-data"
import { SITE_CONFIG } from "@/config/site"
import { buildAlternates, canonicalUrl } from "@/utils/routes"
import { t } from "@/utils/translations"
import { normalizeMetaDescription } from "@/utils/seo"
import { webPageJsonLd, webSiteJsonLd } from "@/utils/structured-data"
import Header from "@/components/ui/Header.astro"
import Footer from "@/components/ui/Footer.astro"
import GTMHead from "@/components/widgets/GTMHead.astro"
import GTMBody from "@/components/widgets/GTMBody.astro"
import Adsense from "@/components/widgets/Adsense.astro"

interface Props {
  path?: string
  title?: string
  description?: string
  image?: string
  imageAlt?: string
  canonicalOverride?: string
  ogType?: "website" | "article"
  articleMeta?: {
    publishedTime: string
    modifiedTime: string
    author: string
    section: string
    tags: string[]
  }
  alternates?: Record<string, string>
  noindex?: boolean
  jsonLd?: unknown
}

const locale = "en"
const {
  path = "/",
  title = SITE_CONFIG.name,
  description,
  image = SITE_CONFIG.defaultOgImage,
  imageAlt,
  canonicalOverride,
  ogType = "website",
  articleMeta,
  alternates: explicitAlternates,
  noindex = false,
  jsonLd,
} = Astro.props
const alternates = explicitAlternates ?? buildAlternates(path)
const fallbackDescription = t(locale, "site.description")
const pageDescription = normalizeMetaDescription(
  description ?? fallbackDescription,
  fallbackDescription
)
const pageTitle =
  title === SITE_CONFIG.name || title.includes(SITE_CONFIG.name)
    ? title
    : `${title} | ${SITE_CONFIG.name}`
const canonical = canonicalOverride ?? canonicalUrl(path)
const absoluteImage = image.startsWith("http")
  ? image
  : `${SITE_CONFIG.url}${image}`
const socialImageAlt = imageAlt ?? pageTitle
const baseJsonLd = [
  webSiteJsonLd(),
  webPageJsonLd({
    path,
    title: pageTitle,
    description: pageDescription,
    image,
  }),
]
const jsonLdItems = jsonLd
  ? baseJsonLd.concat(Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : baseJsonLd
const modelContextSearchDescription = `Search ${SITE_CONFIG.name} public editorial content.`
const modelContextSearchTitle = `${SITE_CONFIG.name} search`
const languageAlternates = noindex
  ? undefined
  : Object.entries(alternates).map(([hrefLang, href]) => ({
      hrefLang,
      href,
    }))
---

<html lang={SITE_LANGUAGE_VALUE} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="content-language" content={SITE_LANGUAGE_VALUE} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <SEO
      title={pageTitle}
      description={pageDescription}
      canonical={canonical}
      noindex={noindex}
      languageAlternates={languageAlternates}
      openGraph={{
        basic: {
          title: pageTitle,
          type: ogType,
          image: absoluteImage,
          url: canonical,
        },
        optional: {
          description: pageDescription,
          locale: SITE_OG_LOCALE_VALUE,
          localeAlternate: [],
          siteName: SITE_CONFIG.name,
        },
        image: {
          alt: socialImageAlt,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: SITE_CONFIG.social.xHandle,
        creator: SITE_CONFIG.social.xHandle,
        title: pageTitle,
        description: pageDescription,
        image: absoluteImage,
        imageAlt: socialImageAlt,
      }}
    />
    {
      articleMeta && (
        <>
          <meta property="article:published_time" content={articleMeta.publishedTime} />
          <meta property="article:modified_time" content={articleMeta.modifiedTime} />
          <meta property="article:author" content={articleMeta.author} />
          <meta property="article:section" content={articleMeta.section} />
          {articleMeta.tags.map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        </>
      )
    }
    <script is:inline>
      ;(() => {
        const theme = localStorage.getItem("theme") || "system"
        const resolved =
          theme === "system"
            ? matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
            : theme
        document.documentElement.classList.toggle("dark", resolved === "dark")
      })()
    </script>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdItems)}
    />
    <script
      is:inline
      define:vars={{ modelContextSearchDescription, modelContextSearchTitle }}
    >
      ;(() => {
        const modelContext = navigator.modelContext
        if (!modelContext || typeof modelContext.registerTool !== "function") return

        const controller = new AbortController()
        modelContext.registerTool(
          {
            name: "site_search",
            description: modelContextSearchDescription,
            inputSchema: {
              type: "object",
              properties: {
                query: {
                  type: "string",
                  description: "Search query.",
                },
              },
              required: ["query"],
              additionalProperties: false,
            },
            execute: async ({ query }) => {
              const path = `/search/?q=${encodeURIComponent(query)}`
              return {
                url: new URL(path, location.origin).toString(),
                title: modelContextSearchTitle,
              }
            },
          },
          { signal: controller.signal }
        )

        document.addEventListener("astro:before-swap", () => controller.abort(), {
          once: true,
        })
      })()
    </script>
    <GTMHead />
    <Adsense />
  </head>
  <body>
    <GTMBody />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import Layout from "@/layouts/main.astro"
import ProfileCard from "@/components/cards/ProfileCard.astro"
import CredibilityStrip from "@/components/cards/CredibilityStrip.astro"
import Icon from "@/components/ui/Icon.astro"
import { getAuthor } from "@/utils/content"
import { getPage } from "@/utils/content"
import { render } from "astro:content"

const author = await getAuthor("default")
const aboutPage = await getPage("about")
const { Content } = aboutPage ? await render(aboutPage) : { Content: null }
const title = aboutPage?.data?.title ?? "About"
const description =
  aboutPage?.data?.description ??
  "About Nite Tanzarn — intellectual infrastructure for structural equity."
---

<Layout
  path="/about/"
  title={title}
  description={description}
>
  <section
    class="mx-auto w-full max-w-3xl px-5 py-12 sm:px-7 sm:py-20"
  >
    <header class="mb-12 flex flex-col gap-3">
      <span class="section-rule" aria-hidden="true"></span>
      <p class="eyebrow">About</p>
      <h1 class="article-title">{title}</h1>
      <p class="font-serif text-lg leading-8 opacity-85 sm:text-xl">
        {description}
      </p>
    </header>

    {aboutPage ? (
      <div class="article-prose">
        {Content ? <Content /> : null}
      </div>
    ) : null}
  </section>

  {author ? (
    <section
      class="mx-auto w-full max-w-6xl px-5 pb-12 sm:px-7 sm:pb-16"
    >
      <ProfileCard author={author} ctaHref="/contact/" ctaLabel="Get in touch" />
    </section>
  ) : null}

  {author ? (
    <section
      class="mx-auto w-full max-w-6xl px-5 pb-20 sm:px-7 sm:pb-24"
      aria-labelledby="at-a-glance-title"
    >
      <header class="mb-6 flex flex-col gap-3">
        <span class="section-rule" aria-hidden="true"></span>
        <p class="eyebrow">At a glance</p>
        <h2 id="at-a-glance-title" class="section-title">
          Practice in numbers
        </h2>
      </header>
      <CredibilityStrip
        mode="default"
        eyebrow="By the numbers"
      />
    </section>
  ) : null}

  <section
    class="mx-auto w-full max-w-6xl px-5 pb-24 sm:px-7"
  >
    <div class="flex flex-wrap items-center gap-3 border-t border-current/20 pt-6">
      <a class="btn-primary" href="/contact/">
        <Icon name="mail" class="size-4" dataIcon="inline-start" />
        <span>Get in touch</span>
      </a>
      <a
        class="inline-flex items-center gap-1 underline-offset-4 hover:underline"
        href="/posts/"
      >
        <span>Read essays</span>
        <Icon name="arrow-right" class="size-4" />
      </a>
    </div>
  </section>
</Layout>

---
import { getEntry, render } from "astro:content"
import Layout from "@/layouts/main.astro"
import ProseContent from "@/components/layout/ProseContent.astro"

const entry = await getEntry("page", "en/annotations")
if (!entry) {
  throw new Error("Missing page entry: en/annotations")
}
const { Content } = await render(entry)
---

<Layout
  path="/annotations/"
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.noindex}
>
  <article
    class="mx-auto max-w-3xl px-4 py-12 sm:px-6"
    data-pagefind-body
  >
    <header class="mb-10">
      <h1
        class="text-balance text-3xl font-semibold leading-tight tracking-tight sm:text-4xl"
      >
        {entry.data.title}
      </h1>
      {entry.data.description && (
        <p class="mt-3 max-w-2xl text-base text-muted-foreground sm:text-lg">
          {entry.data.description}
        </p>
      )}
    </header>
    <ProseContent class="article-prose max-w-none">
      <Content />
    </ProseContent>
  </article>
</Layout>
